# =============================================================================
# Pulse — Environment configuration
# Copy this file to .env and fill in the values.
# Never commit .env with real secrets.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_dev_only
POSTGRES_DB=pulse
# Async SQLAlchemy DSN (used by the api service)
DATABASE_URL=postgresql+asyncpg://pulse:pulse_dev_only@db:5432/pulse

# --- Quiver vector database ---------------------------------------------------
# URL of the running Quiver service (default: internal docker network)
QUIVER_URL=http://quiver:8080
# API key configured on the Quiver server (change before any real deployment)
QUIVER_API_KEY=dev-quiver-key-change-me

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- JWT authentication -------------------------------------------------------
# Must be at least 32 characters for production; generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Groq LLM (required for AI features only) ---------------------------------
# Get a key at https://console.groq.com — app starts and seeds without this key;
# only the Copilot, RAG answers, AI summaries, and report narratives require it.
GROQ_API_KEY=
# Default model for the generate node
GROQ_MODEL=llama-3.3-70b-versatile
# Faster model used by the router node
GROQ_ROUTER_MODEL=llama-3.1-8b-instant
# Temperature for generation (0.0–1.0)
GROQ_TEMPERATURE=0.3

# --- Embeddings ---------------------------------------------------------------
# Sentence-transformer model for encoding documents and queries
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Enable/disable cross-encoder reranking (true | false)
RERANK_ENABLED=true
# Cross-encoder model for reranking retrieved chunks
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- API service --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# development | production
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins (Next.js dev + prod)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Demo credentials (seed only — change before any real deployment) ---------
# These are seeded into the database by `task seed` for demo purposes.
DEMO_SURGEON_EMAIL=surgeon@demo.pulse
DEMO_SURGEON_PASSWORD=demo-surgeon-2024
DEMO_ANESTHETIST_EMAIL=anesthetist@demo.pulse
DEMO_ANESTHETIST_PASSWORD=demo-anesthetist-2024
DEMO_NURSE_EMAIL=nurse@demo.pulse
DEMO_NURSE_PASSWORD=demo-nurse-2024
DEMO_ADMIN_EMAIL=admin@demo.pulse
DEMO_ADMIN_PASSWORD=demo-admin-2024
